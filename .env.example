# The Odds API — https://the-odds-api.com/
# Requerido para: python predictor.py -odds fanduel
ODDS_API_KEY=your_odds_api_key_here

# RapidAPI (Tank01) — para reportes de lesiones
# Opcional: sin clave, AVAIL=1.0 para todos los equipos (fallback seguro)
RAPIDAPI_KEY=your_rapidapi_key_here

# Telegram Bot — para notificaciones automáticas
# Opcional: sin estas claves, la automatización Telegram no funciona
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Sportsbook por defecto para odds
DEFAULT_SPORTSBOOK=fanduel

# Nivel de logging: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
